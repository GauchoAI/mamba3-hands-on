//
// Naive FP32 matmul, hand-written PTX for H100 (sm_90).
//
// C[row, col] = sum_k A[row, k] * B[k, col]
//
// Row-major. Each thread computes one C element.
// Block: 16x16 threads.  Grid: ceil(N/16) x ceil(M/16).
//
// Uses fma.rn.f32: IEEE round-to-nearest-even FMA, no contraction, no fast math.
// This is the whole point of going PTX — we pin the precision ourselves.
//

.version 7.8
.target sm_90
.address_size 64

.visible .entry matmul_naive_f32(
    .param .u64 param_A,
    .param .u64 param_B,
    .param .u64 param_C,
    .param .u32 param_M,
    .param .u32 param_N,
    .param .u32 param_K
)
{
    .reg .u32   %tidx, %tidy, %bidx, %bidy, %bdimx, %bdimy;
    .reg .u32   %M, %N, %K, %row, %col, %i, %tmp32;
    .reg .u64   %a_base, %b_base, %c_base, %a_ptr, %b_ptr, %c_ptr, %off64;
    .reg .f32   %acc, %av, %bv;
    .reg .pred  %p;

    ld.param.u64        %a_base, [param_A];
    ld.param.u64        %b_base, [param_B];
    ld.param.u64        %c_base, [param_C];
    ld.param.u32        %M,      [param_M];
    ld.param.u32        %N,      [param_N];
    ld.param.u32        %K,      [param_K];

    cvta.to.global.u64  %a_base, %a_base;
    cvta.to.global.u64  %b_base, %b_base;
    cvta.to.global.u64  %c_base, %c_base;

    mov.u32             %tidx,  %tid.x;
    mov.u32             %tidy,  %tid.y;
    mov.u32             %bidx,  %ctaid.x;
    mov.u32             %bidy,  %ctaid.y;
    mov.u32             %bdimx, %ntid.x;
    mov.u32             %bdimy, %ntid.y;

    // row = bidy * bdimy + tidy
    mad.lo.u32          %row, %bidy, %bdimy, %tidy;
    // col = bidx * bdimx + tidx
    mad.lo.u32          %col, %bidx, %bdimx, %tidx;

    // Bounds check
    setp.ge.u32         %p, %row, %M;
    @%p bra             L_DONE;
    setp.ge.u32         %p, %col, %N;
    @%p bra             L_DONE;

    mov.f32             %acc, 0f00000000;
    mov.u32             %i, 0;

L_LOOP:
    setp.ge.u32         %p, %i, %K;
    @%p bra             L_END;

    // a_ptr = A + (row*K + i) * 4
    mul.lo.u32          %tmp32, %row, %K;
    add.u32             %tmp32, %tmp32, %i;
    mul.wide.u32        %off64, %tmp32, 4;
    add.u64             %a_ptr, %a_base, %off64;
    ld.global.f32       %av, [%a_ptr];

    // b_ptr = B + (i*N + col) * 4
    mul.lo.u32          %tmp32, %i, %N;
    add.u32             %tmp32, %tmp32, %col;
    mul.wide.u32        %off64, %tmp32, 4;
    add.u64             %b_ptr, %b_base, %off64;
    ld.global.f32       %bv, [%b_ptr];

    // acc = av * bv + acc, round-to-nearest-even
    fma.rn.f32          %acc, %av, %bv, %acc;

    add.u32             %i, %i, 1;
    bra                 L_LOOP;

L_END:
    // c_ptr = C + (row*N + col) * 4
    mul.lo.u32          %tmp32, %row, %N;
    add.u32             %tmp32, %tmp32, %col;
    mul.wide.u32        %off64, %tmp32, 4;
    add.u64             %c_ptr, %c_base, %off64;
    st.global.f32       [%c_ptr], %acc;

L_DONE:
    ret;
}
